# Copy this file to .env.local for local development with `vercel dev`
# Also set these in the Vercel dashboard for production

# Required: Your Resend API key (https://resend.com → API Keys)
RESEND_API_KEY=re_your_key_here

# Optional: Where to deliver form submissions.
# For multiple recipients, separate with commas (no spaces required).
TO_EMAIL=mads@conviviumco.com,admin@conviviumco.com

# Optional: Sender address (must use a domain you've verified in Resend)
FROM_EMAIL=website@conviviumco.com
